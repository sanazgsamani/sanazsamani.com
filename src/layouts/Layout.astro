---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sanaz Samani — Unlock Your Full Potential",
  description = "Discover self-love and unlock your full potential. Fitness, nutrition, and mindset coaching to transform your lifestyle mentally, physically, and spiritually."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Sanaz Samani" />

  <!-- SEO -->
  <meta name="keywords" content="fitness, nutrition, wellness, workout programs, online personal training, self love, mindset, women's fitness, healthy recipes, digital products" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://sanazsamani.com" />

  <!-- Open Graph (link previews on Instagram, iMessage, WhatsApp, etc.) -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://sanazsamani.com" />
  <meta property="og:image" content="https://sanazsamani.com/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Sanaz Samani" />

  <!-- Twitter/X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://sanazsamani.com/og-image.jpg" />
  <meta name="twitter:creator" content="@sanazsamanii" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <slot />
</body>
</html>
