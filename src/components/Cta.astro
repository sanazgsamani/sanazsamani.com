<section class="py-36 px-6 bg-beige text-center relative overflow-hidden" id="cta">
  <div class="orb absolute w-[500px] h-[500px] -top-[100px] -right-[100px]" style="background: radial-gradient(circle, rgba(168,181,160,0.12) 0%, transparent 70%); animation: orbFloat2 22s ease-in-out infinite;"></div>
  <div class="reveal">
    <h3 class="font-sans text-xs font-semibold tracking-[0.15em] uppercase text-sage-deep mb-4">Join the Movement</h3>
    <h2 class="font-serif font-normal mb-4" style="font-size: clamp(2rem, 4vw, 3.4rem);">Let's grow together</h2>
    <p class="text-base text-text-light mb-10 max-w-[480px] mx-auto leading-[1.7]">
      Get weekly nutrition tips, workout routines, and the motivation you need to become the best version of yourself.
    </p>
    <form class="flex flex-col sm:flex-row gap-3 max-w-[480px] mx-auto relative z-1" onsubmit="event.preventDefault();">
      <input
        type="email"
        placeholder="Your email address"
        class="flex-1 px-7 py-[18px] font-sans text-[15px] border border-warm/40 rounded-full bg-white text-text outline-none transition-all duration-300 focus:border-sage focus:shadow-[0_0_0_4px_rgba(168,181,160,0.15)]"
      />
      <button
        type="submit"
        class="px-9 py-[18px] font-sans text-[13px] font-semibold tracking-[0.08em] uppercase border-none rounded-full bg-forest text-white cursor-pointer transition-all duration-400 whitespace-nowrap hover:bg-forest-dark hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(61,90,62,0.2)]"
      >
        Join
      </button>
    </form>
  </div>
</section>
