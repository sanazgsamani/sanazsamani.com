          <line x1="0" y1="360" x2="400" y2="360" stroke="#ffffff" stroke-width="0.3" stroke-opacity="0.06"/>
          <line x1="133" y1="0" x2="133" y2="540" stroke="#ffffff" stroke-width="0.3" stroke-opacity="0.06"/>
          <line x1="266" y1="0" x2="266" y2="540" stroke="#ffffff" stroke-width="0.3" stroke-opacity="0.06"/>

          <!-- Top label -->
