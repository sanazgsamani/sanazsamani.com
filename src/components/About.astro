<section class="py-40 px-6 bg-white flex justify-center" id="about">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 max-w-[1100px] items-center">
    <!-- Visual -->
    <div class="reveal-left flex items-center justify-center">
