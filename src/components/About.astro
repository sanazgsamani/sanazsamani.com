          <rect width="400" height="540" fill="#1C2D1E"/>

          <!-- Subtle grid lines -->
          <line x1="0" y1="180" x2="400" y2="180" stroke="#ffffff" stroke-width="0.3" stroke-opacity="0.06"/>
