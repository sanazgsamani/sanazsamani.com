          <circle cx="360" cy="40" r="2" fill="#A4BF8B" fill-opacity="0.3"/>
          <circle cx="40" cy="500" r="2" fill="#A4BF8B" fill-opacity="0.3"/>
          <circle cx="360" cy="500" r="2" fill="#A4BF8B" fill-opacity="0.3"/>
