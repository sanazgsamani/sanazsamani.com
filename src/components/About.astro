          <line x1="140" y1="122" x2="260" y2="122" stroke="#A4BF8B" stroke-width="0.6" stroke-opacity="0.3"/>

          <!-- MOVE -->
          <text x="200" y="210" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-style="italic" font-size="72" fill="#F5F0E8" fill-opacity="0.95" letter-spacing="-1">Move</text>
          <line x1="60" y1="228" x2="340" y2="228" stroke="#A4BF8B" stroke-width="0.5" stroke-opacity="0.25"/>

          <!-- FUEL -->
          <text x="200" y="305" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-style="italic" font-size="72" fill="#A4BF8B" fill-opacity="0.85" letter-spacing="-1">Fuel</text>
          <line x1="60" y1="323" x2="340" y2="323" stroke="#A4BF8B" stroke-width="0.5" stroke-opacity="0.25"/>

          <!-- GROW -->
          <text x="200" y="400" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-style="italic" font-size="72" fill="#F5F0E8" fill-opacity="0.4" letter-spacing="-1">Grow</text>

          <!-- Bottom label -->
          <line x1="140" y1="445" x2="260" y2="445" stroke="#A4BF8B" stroke-width="0.6" stroke-opacity="0.3"/>
