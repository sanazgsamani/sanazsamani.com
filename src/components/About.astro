    <!-- Text -->
    <div class="reveal-right">
      <h3 class="font-sans text-xs font-semibold tracking-[0.15em] uppercase text-sage-deep mb-5">The Mission</h3>
      <h2 class="font-serif font-normal leading-[1.2] mb-6 text-text" style="font-size: clamp(2rem, 3.5vw, 3.2rem);">
        Transform your lifestyle.<br />Mind, body & spirit.
      </h2>
      <p class="text-base leading-[1.85] text-text-light max-w-[460px] mb-8">
        I believe every person has the power to become the strongest, most confident version of themselves. Through fitness, nutrition, and mindset work, I help you build the discipline to show up for yourself every single day.
      </p>
      <div class="flex gap-10">
        <div class="text-center">
          <div class="font-serif text-[2.2rem] font-semibold text-forest leading-none about-stat-number">10K+</div>
          <div class="text-[11px] tracking-[0.08em] uppercase text-text-muted mt-1.5">Community</div>
        </div>
        <div class="text-center">
          <div class="font-serif text-[2.2rem] font-semibold text-forest leading-none about-stat-number">200+</div>
          <div class="text-[11px] tracking-[0.08em] uppercase text-text-muted mt-1.5">Workouts</div>
        </div>
        <div class="text-center">
          <div class="font-serif text-[2.2rem] font-semibold text-forest leading-none about-stat-number">50+</div>
          <div class="text-[11px] tracking-[0.08em] uppercase text-text-muted mt-1.5">Recipes</div>
